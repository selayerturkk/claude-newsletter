# ──────────────────────────────────────────────
# Claude & Co. — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control.
# ──────────────────────────────────────────────

# The Gmail address that will SEND the newsletter
GMAIL_ADDRESS=your-email@gmail.com

# Gmail App Password (NOT your regular Gmail password)
# Generate one at: https://myaccount.google.com/apppasswords
# You need 2-Step Verification enabled first.
# Steps:
#   1. Go to https://myaccount.google.com/security
#   2. Enable 2-Step Verification if not already on
#   3. Go to https://myaccount.google.com/apppasswords
#   4. Select app = "Mail", device = "Other (Custom name)"
#   5. Name it "Claude Dispatch" and click Generate
#   6. Copy the 16-character password (no spaces) and paste below
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# The email address that will RECEIVE the newsletter
RECIPIENT_EMAIL=your-email@gmail.com

# Display name for the sender (optional)
SENDER_NAME=Claude & Co.

# Base URL where newsletters are hosted (for "View in browser" link)
# If you host on GitHub Pages: https://yourusername.github.io/claude-newsletter/newsletters
# If left empty, the "View in browser" banner will not appear in emails.
NEWSLETTER_BASE_URL=

# Google Sheet CSV export URL for subscriber list
# Create a Google Form with an "Email" field. The responses Sheet auto-populates.
# Use this URL format: https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/gviz/tq?tqx=out:csv
# If empty, falls back to RECIPIENT_EMAIL above.
SUBSCRIBERS_SHEET_URL=

# Google Form signup link (shown in the newsletter footer so readers can share)
SIGNUP_FORM_URL=
